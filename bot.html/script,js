document.getElementById('login-btn').addEventListener('click', checkPassword);
document.getElementById('password').addEventListener('keydown', function (event) {
    if (event.key === 'Enter') {
        checkPassword();
    }
});

function checkPassword() {
    const password = document.getElementById('password').value;
    const correctPassword = atob('dnV5dmlsZ2FtMjAwNzIwMjQ='); // Base64 encoded password

    if (password === correctPassword) {
        document.getElementById('auth-section').classList.add('hidden');
        document.getElementById('dashboard').classList.remove('hidden');
        loadWebsiteStatuses();
    } else {
        document.getElementById('error-msg').classList.remove('hidden');
    }
}

function loadWebsiteStatuses() {
    const websites = ['vuyani1.github.io', 'vgames1.github.io', 'vcloud24.github.io'];
    const statusList = document.getElementById('status-list');
    statusList.innerHTML = '';

    websites.forEach(site => {
        const listItem = document.createElement('div');
        listItem.textContent = `Checking status of ${site}...`;
        statusList.appendChild(listItem);

        fetch(`https://${site}`)
            .then(response => {
                listItem.textContent = `${site} is Online`;
            })
            .catch(error => {
                listItem.textContent = `${site} is Offline`;
            });
    });
}

